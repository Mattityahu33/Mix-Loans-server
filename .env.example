PORT=5000

# Preferred PostgreSQL/Supabase connection setting
DATABASE_URL=postgresql://postgres:change_me@db.example.supabase.co:5432/postgres?sslmode=require

# Optional split PostgreSQL settings (used when DATABASE_URL is not set)
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=mix_loans
# PGUSER=postgres
# PGPASSWORD=change_me
# PGSSL=true

# Legacy MySQL env names are still accepted as fallback aliases for host/port/user/password/database
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=change_me
# DB_NAME=mix_loans

JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN_SECONDS=43200
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
ADMIN_FULL_NAME=Mix Loans Admin
